# Copy to .env and fill in your values

# LLM backend: "huggingface" (default), "ollama" (GPU server), or "claude"
LLM_BACKEND=huggingface

# HuggingFace Inference API (free tier works for most open models)
# Get your token at: https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_your_token_here
# Free-tier models that work well:
#   meta-llama/Llama-3.1-8B-Instruct  (recommended)
#   mistralai/Mistral-7B-Instruct-v0.3
#   Qwen/Qwen2.5-7B-Instruct
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Ollama GPU server (switch to this when your server is back up)
# LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://your-gpu-server:11434
OLLAMA_MODEL=llama3.1

# Claude / Anthropic API (optional alternative)
# LLM_BACKEND=claude
# ANTHROPIC_API_KEY=your-key-here
# CLAUDE_MODEL=claude-sonnet-4-6

# Embedding model (fastembed, runs locally — no token needed)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# RAG tuning
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K=6
